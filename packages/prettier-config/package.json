{
	"name": "@kitschpatrol/prettier-config",
	"version": "7.4.0",
	"description": "Prettier configuration for @kitschpatrol/shared-config.",
	"keywords": [
		"shared-config",
		"prettier-config",
		"prettier",
		"cli",
		"ksc",
		"ksc-prettier"
	],
	"homepage": "https://github.com/kitschpatrol/shared-config/tree/main/packages/prettier-config",
	"bugs": "https://github.com/kitschpatrol/shared-config/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/shared-config.git",
		"directory": "packages/prettier-config"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"ksc-prettier": "bin/cli.js"
	},
	"files": [
		"bin/*",
		"dist/*",
		"init/*"
	],
	"scripts": {
		"build": "tsdown",
		"cli": "node ./bin/cli.js",
		"prepublishOnly": "pnpm build",
		"test": "vitest run"
	},
	"dependencies": {
		"@kitschpatrol/prettier-plugin-astro": "0.14.1-fork.2",
		"@pinojs/json-colorizer": "^4.0.0",
		"@prettier/plugin-php": "^0.25.0",
		"@prettier/plugin-ruby": "^4.0.4",
		"@prettier/plugin-xml": "^3.4.2",
		"cosmiconfig": "^9.0.1",
		"cosmiconfig-typescript-loader": "^6.3.0",
		"decircular": "^1.0.0",
		"deepmerge": "^4.3.1",
		"deepmerge-ts": "^7.1.5",
		"execa": "^9.6.1",
		"find-workspaces": "^0.3.1",
		"fs-extra": "^11.3.4",
		"json-stringify-pretty-compact": "^4.0.0",
		"package-up": "^5.0.0",
		"picocolors": "^1.1.1",
		"prettier": "^3.8.2",
		"prettier-plugin-jsdoc": "^1.8.0",
		"prettier-plugin-packagejson": "^3.0.2",
		"prettier-plugin-sh": "^0.18.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"prettier-plugin-toml": "^2.0.6",
		"sort-package-json": "^3.6.1",
		"yargs": "^18.0.0"
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
