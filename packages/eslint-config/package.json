{
	"name": "@kitschpatrol/eslint-config",
	"version": "5.13.0",
	"description": "ESLint configuration for @kitschpatrol/shared-config.",
	"keywords": [
		"shared-config",
		"eslint-config",
		"eslint",
		"cli",
		"ksc",
		"ksc-eslint"
	],
	"homepage": "https://github.com/kitschpatrol/shared-config/tree/main/packages/eslint-config",
	"bugs": "https://github.com/kitschpatrol/shared-config/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/shared-config.git",
		"directory": "packages/eslint-config"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"ksc-eslint": "bin/cli.js"
	},
	"files": [
		"bin/*",
		"dist/*",
		"init/*"
	],
	"scripts": {
		"build": "tsdown",
		"cli": "node ./bin/cli.js",
		"inspect": "npx @eslint/config-inspector --config ./init/eslint.config.ts",
		"prepublishOnly": "pnpm run build",
		"update-rules": "tsx scripts/presetgen.ts && tsx scripts/typegen.ts && cd ../../ && ksc-eslint fix $PWD && ksc-prettier fix $PWD"
	},
	"dependencies": {
		"@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
		"@eslint-react/eslint-plugin": "2.1.1",
		"@html-eslint/eslint-plugin": "^0.55.0",
		"@html-eslint/parser": "^0.55.0",
		"@pinojs/json-colorizer": "^4.0.0",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"@vitest/eslint-plugin": "^1.6.9",
		"astro-eslint-parser": "^1.3.0",
		"cosmiconfig": "^9.0.0",
		"cosmiconfig-typescript-loader": "^6.2.0",
		"decircular": "^1.0.0",
		"deepmerge": "^4.3.1",
		"eslint": "^9.39.3",
		"eslint-config-flat-gitignore": "^2.2.1",
		"eslint-flat-config-utils": "^3.0.1",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-mdx": "^3.6.2",
		"eslint-plugin-astro": "^1.6.0",
		"eslint-plugin-de-morgan": "^2.0.0",
		"eslint-plugin-depend": "^1.4.0",
		"eslint-plugin-html": "^8.1.4",
		"eslint-plugin-import-x": "^4.16.1",
		"eslint-plugin-jsdoc": "^62.7.0",
		"eslint-plugin-jsonc": "^2.21.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-mdx": "^3.6.2",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-no-only-tests": "^3.3.0",
		"eslint-plugin-package-json": "^0.88.3",
		"eslint-plugin-perfectionist": "^5.6.0",
		"eslint-plugin-regexp": "^3.0.0",
		"eslint-plugin-svelte": "^3.15.0",
		"eslint-plugin-toml": "^1.1.1",
		"eslint-plugin-unicorn": "^63.0.0",
		"eslint-plugin-yml": "^3.2.1",
		"execa": "^9.6.1",
		"find-workspaces": "^0.3.1",
		"fs-extra": "^11.3.3",
		"globals": "^17.3.0",
		"json-stringify-pretty-compact": "^4.0.0",
		"jsonc-eslint-parser": "^3.1.0",
		"local-pkg": "^1.1.2",
		"package-up": "^5.0.0",
		"picocolors": "^1.1.1",
		"prettier": "^3.8.1",
		"sort-package-json": "^3.6.1",
		"svelte-eslint-parser": "^1.4.1",
		"toml-eslint-parser": "^1.0.3",
		"yaml-eslint-parser": "^2.0.0",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@types/eslint-config-prettier": "^6.11.3",
		"@types/eslint-plugin-jsx-a11y": "^6.10.1",
		"dot-prop": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-config-xo-typescript": "^9.0.0",
		"eslint-typegen": "^2.3.1",
		"globby": "^16.1.1",
		"svelte": "^5.53.0"
	},
	"engines": {
		"node": ">=22.21.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
