{
	"name": "shared-config-monorepo",
	"version": "7.4.1",
	"private": true,
	"description": "A single dependency and CLI command to configure and run various linters and code quality tools in TypeScript projects.",
	"keywords": [
		"shared-config",
		"eslint-config",
		"stylelint-config",
		"prettier-config",
		"typescript-config",
		"remark-config",
		"remark-lint",
		"github-actions",
		"cspell",
		"tsconfig",
		"mdat",
		"cli",
		"ksc",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/shared-config",
	"bugs": "https://github.com/kitschpatrol/shared-config/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/shared-config.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"scripts": {
		"bin-ignore": "git ls-files | grep cli.js | xargs -I {} git update-index --skip-worktree {}",
		"bin-restore": "pnpm bin-unignore && git ls-files | grep cli.js | xargs -I {} git restore --source HEAD -- {} && pnpm bin-ignore",
		"bin-unignore": "git ls-files | grep cli.js | xargs -I {} git update-index --no-skip-worktree {}",
		"build": "pnpm build:1-stand-alone && pnpm build:2-shared && pnpm build:3-readmes",
		"build:1-stand-alone": "pnpm --filter=!shared-config --filter=!shared-config-monorepo build",
		"build:2-shared": "pnpm --filter=shared-config build",
		"build:3-readmes": "pnpm ksc-mdat fix && shx cp ./packages/shared-config/readme.md ./readme.md && mdat strip",
		"clean": "shx rm -f pnpm-lock.yaml && pnpm bin-restore && git clean -fdX -e !.claude/",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"merge-ignores": "ksdiff --merge ./packages/eslint-config/.eslintignore ./packages/stylelint-config/.stylelintignore",
		"release": "pnpm build && bumpp -r --commit 'Release: %s' && pnpm build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm -r publish",
		"test": "vitest run"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@kitschpatrol/cspell-config": "workspace:*",
		"@kitschpatrol/eslint-config": "workspace:*",
		"@kitschpatrol/knip-config": "workspace:*",
		"@kitschpatrol/mdat-config": "workspace:*",
		"@kitschpatrol/prettier-config": "workspace:*",
		"@kitschpatrol/remark-config": "workspace:*",
		"@kitschpatrol/repo-config": "workspace:*",
		"@kitschpatrol/shared-config": "workspace:*",
		"@kitschpatrol/stylelint-config": "workspace:*",
		"@kitschpatrol/typescript-config": "workspace:*",
		"@pinojs/json-colorizer": "^4.0.0",
		"@pnpm/lockfile.types": "^1100.0.0",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "~22.18.13",
		"@types/react": "^19.2.14",
		"@types/semver": "^7.7.1",
		"@types/yargs": "^17.0.35",
		"bumpp": "^11.0.1",
		"cosmiconfig": "^9.0.1",
		"cosmiconfig-typescript-loader": "^6.3.0",
		"decircular": "^1.0.0",
		"deepmerge": "^4.3.1",
		"execa": "^9.6.1",
		"find-workspaces": "^0.3.1",
		"fs-extra": "^11.3.4",
		"json-stringify-pretty-compact": "^4.0.0",
		"mdat": "^2.2.1",
		"mdat-plugin-cli-help": "^2.1.2",
		"package-up": "^5.0.0",
		"picocolors": "^1.1.1",
		"prettier": "^3.8.2",
		"publint": "^0.3.18",
		"shx": "^0.4.0",
		"tsdown": "^0.21.8",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"vitest": "^4.1.4",
		"yargs": "^18.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.18.0"
	}
}
